# AI YouTube Automation - Environment Configuration
# Copy this file to .env and fill in your actual values

# Required: Google Gemini API Key
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Required for YouTube upload: Path to OAuth credentials file
# Download from Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
YOUTUBE_CLIENT_SECRETS_FILE=client_secrets.json

# Optional: Folder paths (defaults shown)
VIDEO_SOURCE_FOLDER=./downloaded_videos
OUTPUT_FOLDER=./output_reels

# Optional: Processing settings
MAX_VIDEO_DURATION=300
GEMINI_MODEL=gemini-2.0-flash-lite

# Optional: Schedule time in 24-hour format (HH:MM)
DAILY_UPLOAD_TIME=09:00
