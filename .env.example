# AI YouTube Shorts — copy to .env and fill in values

# Required: Google Gemini API key
# https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Required for YouTube upload
YOUTUBE_CLIENT_SECRETS_FILE=client_secrets.json

# Optional
OUTPUT_FOLDER=./output_reels
GEMINI_MODEL=gemini-2.0-flash-lite
AUTO_UPLOAD=false

# Topic file: one line = one Short (random unused line each run)
CONTENT_QUEUE_FILE=./content/video_topics.txt
QUEUE_OUTPUT_FOLDER=./output_reels/queue

# Niche context for Gemini scripts
TIP_NICHE=AI tools and productivity for beginners
TTS_VOICE=en-US-JennyNeural

# Channel branding on slides
CHANNEL_NAME=Dailytix
CHANNEL_CTA=Follow Dailytix for daily tips
TIP_BG_COLOR=#0A192F
TIP_BRAND_COLOR=#FF8C00
TIP_TEXT_COLOR=#FFFFFF

# Two automatic runs per day (~12 hours apart, HH:MM)
UPLOAD_TIME_1=09:00
UPLOAD_TIME_2=21:00

# Optional assets (see assets/README.md)
# CHANNEL_LOGO_PATH=./assets/channel_logo.png
# BACKGROUND_MUSIC_PATH=./assets/background_music.mp3
