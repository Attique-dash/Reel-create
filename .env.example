# AI YouTube Automation - Environment Configuration
# Copy this file to .env and fill in your actual values

# Required: Google Gemini API Key
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Required for YouTube upload: Path to OAuth credentials file
# Download from Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
YOUTUBE_CLIENT_SECRETS_FILE=client_secrets.json

# Optional: Folder paths (defaults shown)
VIDEO_SOURCE_FOLDER=./downloaded_videos
OUTPUT_FOLDER=./output_reels

# Optional: Processing settings
MAX_VIDEO_DURATION=300
GEMINI_MODEL=gemini-2.0-flash-lite

# Optional: Schedule time in 24-hour format (HH:MM)
DAILY_UPLOAD_TIME=09:00

# Optional: Auto-upload reels after processing (true/false). Default: false
AUTO_UPLOAD=false

# --- Idea 2: Daily tip Shorts (original faceless content) ---
# Niche for Gemini scripts (English, searchable topics)
TIP_NICHE=AI tools and productivity for beginners
# Where tip videos and JSON are saved (default: ./output_reels/tips)
TIPS_OUTPUT_FOLDER=./output_reels/tips
# edge-tts voice: en-US-JennyNeural, en-US-GuyNeural, en-GB-SoniaNeural, etc.
TTS_VOICE=en-US-JennyNeural

# Channel branding on slides (match your YouTube channel name)
CHANNEL_NAME=Dailytix
CHANNEL_CTA=Follow Dailytix for daily tips
TIP_BG_COLOR=#0A192F
TIP_BRAND_COLOR=#FF8C00
TIP_TEXT_COLOR=#FFFFFF
TIP_XFADE_DURATION=0.3
TIP_TOTAL_DURATION=28
TIP_SLIDE_DURATIONS=5,6,6,6,5

# Optional assets (see assets/README.md)
# CHANNEL_LOGO_PATH=./assets/channel_logo.png
# BACKGROUND_MUSIC_PATH=./assets/background_music.mp3
