# Backend Environment Variables
# Copy this to .env and fill in your values

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
MONGODB_URI=mongodb://localhost:27017/video_processor

# ============================================================================
# CELERY & REDIS CONFIGURATION  
# ============================================================================
# Redis is used as the message broker for Celery task queue
# If Redis is not available, Celery will automatically run in synchronous mode
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ============================================================================
# STORAGE CONFIGURATION
# ============================================================================
# Directories where videos and processed files are stored
UPLOAD_DIR=./storage/uploads
PROCESSED_DIR=./storage/processed
SUBTITLES_DIR=./storage/subtitles

# ============================================================================
# VIDEO PROCESSING DEFAULTS
# ============================================================================
# Number of short clips to generate
DEFAULT_NUM_CLIPS=5

# Duration of each clip in seconds
DEFAULT_CLIP_DURATION=60

# Aspect ratio for short-form content: "9:16" (vertical), "1:1" (square), or "16:9" (horizontal)
DEFAULT_ASPECT_RATIO=9:16

# ============================================================================
# AI & EXTERNAL SERVICES
# ============================================================================
# Google Gemini API Key for AI-powered moment analysis
# Get it from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
# Environment: development, testing, or production
ENVIRONMENT=development

# Enable debug logging
DEBUG=True

# Maximum file upload size in MB
MAX_UPLOAD_SIZE=500

# ============================================================================
# LOGGING
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# NOTES
# ============================================================================
# 1. For local development, you can leave Redis settings as-is
# 2. If Redis is not running, Celery will run synchronously
# 3. Make sure FFmpeg is installed: brew install ffmpeg (macOS)
# 4. Make sure MongoDB is running: mongod or docker-compose up
